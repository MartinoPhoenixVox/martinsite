---
layout: none
---
[
  {% for book in site.books %}
    {
      "title": {{ book.title | jsonify }},
      "tags": {{ book.tags | join: ', ' | jsonify }},
      "url": {{ book.url | relative_url | jsonify }},
      "author": {{ book.author | default: "Đang cập nhật" | jsonify }}
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]